---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const {
  title,
  description = 'Dr. L. June Bloch — anthropologist, ethnic studies scholar, and builder of research tools that interrogate constitutive power relations and structural violence.',
  wide = false,
} = Astro.props;

const siteTitle = title === 'Home'
  ? 'L. June Bloch — Anthropologist, Ethnic Studies Scholar, Builder'
  : `${title} — L. June Bloch`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/headshot-rect.png', Astro.site);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="L. June Bloch" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="L. June Bloch" />

    <!-- Twitter / social cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "L. June Bloch",
      "url": "https://ljunebloch.com",
      "image": "https://ljunebloch.com/images/headshot-rect.png",
      "jobTitle": "Anthropologist & Ethnic Studies Scholar",
      "description": "Anthropologist, ethnic studies scholar, and builder of research tools that interrogate constitutive power relations and structural violence.",
      "sameAs": [
        "https://github.com/grouchyseafowl",
        "https://bsky.app/profile/disabledbydesign.bsky.social",
        "https://www.linkedin.com/in/l-june-bloch-1897a329/",
        "https://scholar.google.com/citations?user=9bQ8kjIAAAAJ"
      ]
    })} />

    <title>{siteTitle}</title>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Nav />
    <main id="main-content" class:list={['container', { 'container--wide': wide }]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
