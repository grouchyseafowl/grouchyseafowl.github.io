---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Dr. L. June Bloch — email, social media, and professional links."
>
  <div class="page-header">
    <h1>Contact</h1>
    <p class="subtitle">For academic inquiries, speaking, collaboration, or just saying hello.</p>
  </div>

  <div class="contact-content">
    <p class="contact-email">
      <a href="mailto:june@ljunebloch.com">june@ljunebloch.com</a>
    </p>

    <ul class="contact-links">
      <li>
        <span class="link-label">Bluesky</span>
        <a href="https://bsky.app/profile/disabledbydesign.bsky.social">@disabledbydesign.bsky.social</a>
      </li>
      <li>
        <span class="link-label">GitHub</span>
        <a href="https://github.com/grouchyseafowl">grouchyseafowl</a>
      </li>
      <li>
        <span class="link-label">Google Scholar</span>
        <a href="https://scholar.google.com/citations?user=9bQ8kjIAAAAJ&hl=en&oi=ao">Publication record</a>
      </li>
      <li>
        <span class="link-label">LinkedIn</span>
        <a href="https://www.linkedin.com/in/l-june-bloch-1897a329/">L. June Bloch</a>
      </li>
    </ul>
  </div>
</BaseLayout>

<style>
  .contact-content {
    max-width: 65ch;
  }

  .contact-email {
    margin-bottom: var(--space-xl);
  }

  .contact-email a {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    color: var(--amber);
    font-weight: 400;
  }

  .contact-email a:hover {
    color: var(--amber-mid);
  }

  .contact-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-links li {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--border);
  }

  .contact-links li:last-child {
    border-bottom: none;
  }

  .link-label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    min-width: 10rem;
    flex-shrink: 0;
  }

  .contact-links a {
    font-size: var(--text-base);
  }

  @media (max-width: 480px) {
    .contact-email a {
      font-size: var(--text-xl);
    }

    .contact-links li {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .link-label {
      min-width: auto;
    }
  }
</style>
