---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="CV"
  description="Curriculum vitae for Dr. L. June Bloch — anthropologist, ethnic studies scholar, and builder."
>
  <div class="page-header cv-header">
    <h1>Curriculum Vitae</h1>
    <a href="/files/Bloch_CV.pdf" class="cv-download" download>
      Download CV (PDF)
    </a>
  </div>

  <div class="cv-layout">
    <div class="cv-main">

      <section class="card cv-section">
        <h2>Education</h2>
        <div class="cv-entry">
          <div class="cv-when">2018</div>
          <div class="cv-what">
            <p><strong>Ph.D., Anthropology</strong> &mdash; University of Virginia</p>
            <p class="cv-detail">Advisor: Jeffrey Hantman. Dissertation: <em>Sweetgum's Amber: Animate Mound Landscapes and the Nonlinear Longue Dur&eacute;e in the Native South</em></p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2014</div>
          <div class="cv-what">
            <p><strong>M.A., Anthropology</strong> &mdash; University of Virginia</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2011</div>
          <div class="cv-what">
            <p><strong>B.A., Anthropology / Gender Studies</strong> &mdash; New College of Florida</p>
            <p class="cv-detail">Honors Thesis: <em>An Anthropology of Remembering: Queer Theory, Collaborative Archaeology, and the Apalachee Past</em></p>
          </div>
        </div>
      </section>

      <section class="card cv-section">
        <h2>Academic Positions</h2>
        <div class="cv-entry">
          <div class="cv-when">2025&ndash;Present</div>
          <div class="cv-what">
            <p><strong>Professor of Ethnic Studies</strong> &mdash; Cabrillo College</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2024&ndash;25</div>
          <div class="cv-what">
            <p><strong>Visiting Assistant Professor</strong> &mdash; College of Charleston</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2020&ndash;24</div>
          <div class="cv-what">
            <p><strong>Visiting Assistant Professor / Instructor</strong> &mdash; Agnes Scott College</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2018&ndash;20</div>
          <div class="cv-what">
            <p><strong>Florence Levy Kay Fellow</strong> &mdash; Brandeis University</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2016</div>
          <div class="cv-what">
            <p><strong>Instructor</strong> &mdash; University of Virginia</p>
          </div>
        </div>
      </section>

      <section class="card cv-section">
        <h2>DEI &amp; Other Employment</h2>
        <div class="cv-entry">
          <div class="cv-when">2016&ndash;Present</div>
          <div class="cv-what">
            <p><strong>Independent DEI Consultant</strong> &mdash; iChange Collaborative</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2020&ndash;22</div>
          <div class="cv-what">
            <p><strong>Independent DEI Consultant</strong> &mdash; Both And Partners</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2018</div>
          <div class="cv-what">
            <p><strong>Archivist</strong> &mdash; Charlottesville Digital Archive Project</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2017&ndash;18</div>
          <div class="cv-what">
            <p><strong>Tribal Outreach Coordinator</strong> &mdash; Indigenous Ecologies Workshop, UVA</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2017</div>
          <div class="cv-what">
            <p><strong>Curatorial Intern</strong> &mdash; Kluge-Ruhe Aboriginal Art Collection, UVA</p>
          </div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">2011&ndash;12</div>
          <div class="cv-what">
            <p><strong>AmeriCorps VISTA</strong> &mdash; University of Miami</p>
          </div>
        </div>
      </section>

      <section class="card cv-section">
        <h2>Grants &amp; Funding</h2>
        <div class="cv-entry">
          <div class="cv-when">$15,000</div>
          <div class="cv-what"><p>NSF Doctoral Dissertation Research Improvement</p></div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">$15,000</div>
          <div class="cv-what"><p>Wenner-Gren Foundation</p></div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">$3,500</div>
          <div class="cv-what"><p>American Philosophical Society</p></div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">$4,000</div>
          <div class="cv-what"><p>Explorers Club</p></div>
        </div>
        <div class="cv-entry">
          <div class="cv-when">~$22,000</div>
          <div class="cv-what"><p>Multiple University of Virginia internal grants</p></div>
        </div>
        <p class="cv-detail" style="margin-top: var(--space-md); padding-left: calc(6rem + var(--space-md));">All grants funded anthropological fieldwork. All tech projects were built without any tech funding.</p>
      </section>

      <section class="card cv-section">
        <h2>Languages</h2>
        <div class="cv-langs">
          <span>English <em class="cv-detail">(native)</em></span>
          <span>Spanish <em class="cv-detail">(conversational)</em></span>
          <span>Muscogee <em class="cv-detail">(beginner)</em></span>
        </div>
      </section>

    </div>

  </div>
</BaseLayout>

<style>
  .cv-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .cv-download {
    display: inline-block;
    padding: var(--space-sm) var(--space-lg);
    background: var(--bg-input);
    border: 1px solid var(--amber-dim);
    border-radius: 6px;
    color: var(--amber);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    transition: border-color var(--transition-base), background-color var(--transition-base);
    white-space: nowrap;
  }

  .cv-download:hover {
    border-color: var(--amber);
    background-color: var(--bg-elevated);
    text-decoration: none;
  }

  .cv-layout {
    width: 100%;
  }

  /* Main column */
  .cv-section {
    padding: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .cv-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: none;
    background-image: linear-gradient(to right,
      rgba(192, 136, 32, 0.7),
      rgba(192, 136, 32, 0.4) 30%,
      rgba(106, 74, 18, 0) 55%);
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: bottom;
  }

  .cv-entry {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: none;
    background-image: linear-gradient(to right,
      rgba(106, 74, 18, 0),
      rgba(192, 136, 32, 0.5) 20%,
      rgba(192, 136, 32, 0.5) 80%,
      rgba(106, 74, 18, 0));
    background-size: 100% 1px;
    background-repeat: no-repeat;
    background-position: bottom;
  }

  .cv-entry:last-child {
    background-image: none;
  }

  .cv-when {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--amber-dim);
    padding-top: 0.15em;
    text-align: right;
  }

  .cv-what p {
    margin-bottom: 0;
  }

  .cv-detail {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-style: normal;
  }

  .cv-langs {
    display: flex;
    gap: var(--space-xl);
  }

  .cv-langs span {
    color: var(--text-primary);
  }

</style>
