---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="hero-text">
      <h1 class="hero-name">L. June Bloch</h1>
      <p class="hero-identity">Anthropologist · Applied AI Builder · World Builder</p>
      <p class="hero-intro">
        <!-- Phase 2: Replace with content from agent briefing + voice document -->
        A humanist who builds — redesigning systems by interrogating constitutive power relations
        and structural violence. Five active research programs spanning Indigenous mound landscapes,
        movement ethnography, anti-trans legislation, recognition and sentience, and AI as a site
        of anthropological inquiry.
      </p>
      <div class="hero-socials">
        <a href="https://scholar.google.com/citations?user=9bQ8kjIAAAAJ&hl=en&oi=ao" aria-label="Google Scholar">Scholar</a>
        <a href="https://bsky.app/profile/disabledbydesign.bsky.social" aria-label="Bluesky">Bluesky</a>
        <a href="https://github.com/grouchyseafowl" aria-label="GitHub">GitHub</a>
      </div>
    </div>
    <div class="hero-image">
      <img
        src="/images/headshot-rect.png"
        alt="Dr. L. June Bloch"
        width="280"
        height="350"
      />
    </div>
  </section>

  <div class="section-label">Explore</div>

  <div class="feature-grid">
    <a href="/research/" class="feature-link">
      <h3 class="amber">Research</h3>
      <p>Five research programs — from Indigenous mound landscapes to AI welfare — connected by questions about recognition, power, and what counts as real.</p>
    </a>

    <a href="/projects/" class="feature-link">
      <h3 class="rose">Projects</h3>
      <p>Research tools built from the ground up. Reframe, Autograder4Canvas, EvalEye — software that embodies the theoretical commitments, not just implements them.</p>
    </a>

    <a href="/publications/" class="feature-link">
      <h3 class="blue">Publications</h3>
      <p>Published in Cultural Anthropology, American Anthropologist, Current Anthropology, and other major journals across anthropology and ethnic studies.</p>
    </a>
  </div>
</BaseLayout>
