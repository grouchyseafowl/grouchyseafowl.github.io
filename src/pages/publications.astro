</BaseLayout>

<style>
  .pub-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* Card per article — compact height */
  .pub-card {
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: 6px;
    transition: border-color var(--transition-base);
  }

  .pub-card:hover {
    border-color: var(--border-hover);
  }

  .pub-card--static {
    cursor: default;
  }

  /* Header: badge left, content right */
  .pub-header {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: var(--space-md);
    align-items: start;
  }

  /* When there's no badge, content spans full width */
  .pub-header > .pub-meta:first-child {
    grid-column: 1 / -1;
  }

  .pub-meta {
    min-width: 0;
  }

  /* Collapsible */
  details.pub-card summary {
    cursor: pointer;
    list-style: none;
  }

  details.pub-card summary::-webkit-details-marker {
    display: none;
  }

  .pub-abstract {
    margin-top: var(--space-sm);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  /* Year badge */
  .pub-year-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--amber);
    background: rgba(240, 168, 48, 0.10);
    border: 1px solid var(--amber-dim);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    white-space: nowrap;
    margin-top: 0.15em;
    text-align: center;
  }

  /* Status badge (In progress, Paused, Submitted) */
  .pub-badge-status {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--rose);
    background: rgba(204, 82, 130, 0.10);
    border: 1px solid var(--rose-dim);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    white-space: nowrap;
    margin-top: 0.15em;
    text-align: center;
  }

  .pub-badge--paused {
    color: var(--text-muted);
    background: rgba(138, 122, 96, 0.10);
    border-color: rgba(138, 122, 96, 0.3);
  }

  .pub-year-badge.tag--rose {
    color: var(--rose);
    background: rgba(204, 82, 130, 0.10);
    border-color: var(--rose-dim);
  }

  /* Typography */
  .pub-card .pub-title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 0.15em;
  }

  .pub-card .pub-venue {
    font-style: italic;
    color: var(--amber-mid);
    font-size: var(--text-xs);
    margin-bottom: 0;
  }

  .pub-card .pub-detail {
    color: var(--text-muted);
    font-size: var(--text-xs);
    margin-bottom: 0;
  }

  .pub-links {
    display: flex;
    gap: var(--space-xs);
    margin-top: 0.25em;
  }

  .pub-links a {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--blue);
    text-decoration: none;
    padding: 0.1em 0.35em;
    border: 1px solid var(--blue-dim);
    border-radius: 3px;
